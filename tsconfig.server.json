{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "outDir": "./dist/server",
    "rootDir": "./server",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo"
  },
  "include": ["server/**/*.ts"]
}
